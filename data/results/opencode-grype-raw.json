","epss":0.00014,"percentile":0.02364,"date":"2026-04-10"}],"cwes":[{"cve":"CVE-2026-25727","cwe":"CWE-121","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.3.47"],"state":"fixed","available":[{"version":"0.3.47","date":"2026-02-06","kind":"first-observed"}]},"advisories":[],"risk":0.008259999999999998},"relatedVulnerabilities":[{"id":"CVE-2026-25727","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-25727","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/time-rs/time/blob/main/CHANGELOG.md#0347-2026-02-05","https://github.com/time-rs/time/commit/1c63dc7985b8fa26bd8c689423cc56b7a03841ee","https://github.com/time-rs/time/releases/tag/v0.3.47","https://github.com/time-rs/time/security/advisories/GHSA-r6v5-fh4h-64xc"],"description":"time provides date and time handling in Rust. From 0.3.6 to before 0.3.47, when user-provided input is provided to any type that parses with the RFC 2822 format, a denial of service attack via stack exhaustion is possible. The attack relies on formally deprecated and rarely-used features that are part of the RFC 2822 format used in a malicious manner. Ordinary, non-malicious input will never encounter this scenario. A limit to the depth of recursion was added in v0.3.47. From this version, an error will be returned rather than exhausting the stack.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:H","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:N/PR:L/UI:A/VC:N/VI:N/VA:H/SC:N/SI:N/SA:H/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":6.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-25727","epss":0.00014,"percentile":0.02364,"date":"2026-04-10"}],"cwes":[{"cve":"CVE-2026-25727","cwe":"CWE-121","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"rust-matcher","searchedBy":{"language":"rust","namespace":"github:language:rust","package":{"name":"time","version":"0.3.44"}},"found":{"vulnerabilityID":"GHSA-r6v5-fh4h-64xc","versionConstraint":">=0.3.6,<0.3.47 (unknown)"},"fix":{"suggestedVersion":"0.3.47"}}],"artifact":{"id":"17a4838b1c945881","name":"time","version":"0.3.44","type":"rust-crate","locations":[{"path":"/packages/desktop/src-tauri/Cargo.lock","accessPath":"/packages/desktop/src-tauri/Cargo.lock","annotations":{"evidence":"primary"}}],"language":"rust","licenses":[],"cpes":["cpe:2.3:a:time:time:0.3.44:*:*:*:*:*:*:*"],"purl":"pkg:cargo/time@0.3.44","upstreams":[]}},{"vulnerability":{"id":"GHSA-gchp-q4r4-x4ff","dataSource":"https://github.com/advisories/GHSA-gchp-q4r4-x4ff","namespace":"github:language:rust","severity":"Medium","urls":["https://github.com/alexcrichton/tar-rs/security/advisories/GHSA-gchp-q4r4-x4ff","https://nvd.nist.gov/vuln/detail/CVE-2026-33055","https://github.com/alexcrichton/tar-rs/commit/de1a5870e603758f430073688691165f21a33946","https://rustsec.org/advisories/RUSTSEC-2026-0068.html","https://www.cve.org/CVERecord?id=CVE-2025-62518"],"description":"tar-rs incorrectly ignores PAX size headers if header size is nonzero","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:N","metrics":{"baseScore":8.1,"exploitabilityScore":2.9,"impactScore":5.2},"vendorMetadata":{}},{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:A/VC:L/VI:L/VA:N/SC:N/SI:N/SA:N","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33055","epss":0.00011,"percentile":0.01422,"date":"2026-04-10"}],"cwes":[{"cve":"CVE-2026-33055","cwe":"CWE-843","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.4.45"],"state":"fixed","available":[{"version":"0.4.45","date":"2026-03-21","kind":"first-observed"}]},"advisories":[],"risk":0.006379999999999999},"relatedVulnerabilities":[{"id":"CVE-2026-33055","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-33055","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/alexcrichton/tar-rs/commit/de1a5870e603758f430073688691165f21a33946","https://github.com/alexcrichton/tar-rs/security/advisories/GHSA-gchp-q4r4-x4ff","https://www.cve.org/CVERecord?id=CVE-2025-62518"],"description":"tar-rs is a tar archive reading/writing library for Rust. Versions 0.4.44 and below have conditional logic that skips the PAX size header in cases where the base header size is nonzero. As part of CVE-2025-62518, the astral-tokio-tar project was changed to correctly honor PAX size headers in the case where it was different from the base header. This is almost the inverse of the astral-tokio-tar issue. Any discrepancy in how tar parsers honor file size can be used to create archives that appear differently when unpacked by different archivers. In this case, the tar-rs (Rust tar) crate is an outlier in checking for the header size - other tar parsers (including e.g. Go archive/tar) unconditionally use the PAX size override. This can affect anything that uses the tar crate to parse archives and expects to have a consistent view with other parsers. This issue has been fixed in version 0.4.45.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:N","metrics":{"baseScore":8.1,"exploitabilityScore":2.9,"impactScore":5.2},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:A/VC:L/VI:L/VA:N/SC:N/SI:N/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33055","epss":0.00011,"percentile":0.01422,"date":"2026-04-10"}],"cwes":[{"cve":"CVE-2026-33055","cwe":"CWE-843","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"rust-matcher","searchedBy":{"language":"rust","namespace":"github:language:rust","package":{"name":"tar","version":"0.4.44"}},"found":{"vulnerabilityID":"GHSA-gchp-q4r4-x4ff","versionConstraint":"<=0.4.44 (unknown)"},"fix":{"suggestedVersion":"0.4.45"}}],"artifact":{"id":"6d2f6eefd03795cd","name":"tar","version":"0.4.44","type":"rust-crate","locations":[{"path":"/packages/desktop/src-tauri/Cargo.lock","accessPath":"/packages/desktop/src-tauri/Cargo.lock","annotations":{"evidence":"primary"}}],"language":"rust","licenses":[],"cpes":["cpe:2.3:a:tar_project:tar:0.4.44:*:*:*:*:rust:*:*"],"purl":"pkg:cargo/tar@0.4.44","upstreams":[]}},{"vulnerability":{"id":"GHSA-j4xf-2g29-59ph","dataSource":"https://github.com/advisories/GHSA-j4xf-2g29-59ph","namespace":"github:language:rust","severity":"Medium","urls":["https://github.com/alexcrichton/tar-rs/security/advisories/GHSA-j4xf-2g29-59ph","https://nvd.nist.gov/vuln/detail/CVE-2026-33056","https://github.com/alexcrichton/tar-rs/commit/17b1fd84e632071cb8eef9d3709bf347bd266446","https://rustsec.org/advisories/RUSTSEC-2026-0067.html"],"description":"tar-rs `unpack_in` can chmod arbitrary directories by following symlinks","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:H/A:N","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}},{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:A/VC:N/VI:L/VA:N/SC:N/SI:N/SA:N","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33056","epss":0.00011,"percentile":0.01451,"date":"2026-04-10"}],"cwes":[{"cve":"CVE-2026-33056","cwe":"CWE-61","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.4.45"],"state":"fixed","available":[{"version":"0.4.45","date":"2026-03-21","kind":"first-observed"}]},"advisories":[],"risk":0.005940000000000001},"relatedVulnerabilities":[{"id":"CVE-2026-33056","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-33056","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/alexcrichton/tar-rs/commit/17b1fd84e632071cb8eef9d3709bf347bd266446","https://github.com/alexcrichton/tar-rs/security/advisories/GHSA-j4xf-2g29-59ph"],"description":"tar-rs is a tar archive reading/writing library for Rust. In versions 0.4.44 and below, when unpacking a tar archive, the tar crate's unpack_dir function uses fs::metadata() to check whether a path that already exists is a directory. Because fs::metadata() follows symbolic links, a crafted tarball containing a symlink entry followed by a directory entry with the same name causes the crate to treat the symlink target as a valid existing directory — and subsequently apply chmod to it. This allows an attacker to modify the permissions of arbitrary directories outside the extraction root. This issue has been fixed in version 0.4.45.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:H/A:N","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:A/VC:N/VI:L/VA:N/SC:N/SI:N/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33056","epss":0.00011,"percentile":0.01451,"date":"2026-04-10"}],"cwes":[{"cve":"CVE-2026-33056","cwe":"CWE-61","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"rust-matcher","searchedBy":{"language":"rust","namespace":"github:language:rust","package":{"name":"tar","version":"0.4.44"}},"found":{"vulnerabilityID":"