ls":["https://github.com/sporkmonger/addressable/security/advisories/GHSA-h27x-rffw-24p4","https://nvd.nist.gov/vuln/detail/CVE-2026-35611"],"description":"Addressable has a Regular Expression Denial of Service in Addressable templates","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-35611","epss":0.00058,"percentile":0.18131,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-35611","cwe":"CWE-1333","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["2.9.0"],"state":"fixed","available":[{"version":"2.9.0","date":"2026-04-08","kind":"first-observed"}]},"advisories":[],"risk":0.0435},"relatedVulnerabilities":[{"id":"CVE-2026-35611","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-35611","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/sporkmonger/addressable/security/advisories/GHSA-h27x-rffw-24p4"],"description":"Addressable is an alternative implementation to the URI implementation that is part of Ruby's standard library. From 2.3.0 to before 2.9.0, within the URI template implementation in Addressable, two classes of URI template generate regular expressions vulnerable to catastrophic backtracking. Templates using the * (explode) modifier with any expansion operator (e.g., {foo*}, {+var*}, {#var*}, {/var*}, {.var*}, {;var*}, {?var*}, {&var*}) generate patterns with nested unbounded quantifiers that are O(2^n) when matched against a maliciously crafted URI. Templates using multiple variables with the + or # operators (e.g., {+v1,v2,v3}) generate patterns with O(n^k) complexity due to the comma separator being within the matched character class, causing ambiguous backtracking across k variables. When matched against a maliciously crafted URI, this can result in catastrophic backtracking and uncontrolled resource consumption, leading to denial of service. This vulnerability is fixed in 2.9.0.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-35611","epss":0.00058,"percentile":0.18131,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-35611","cwe":"CWE-1333","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"ruby-gem-matcher","searchedBy":{"language":"ruby","namespace":"github:language:ruby","package":{"name":"addressable","version":"2.8.9"}},"found":{"vulnerabilityID":"GHSA-h27x-rffw-24p4","versionConstraint":">=2.3.0,<2.9.0 (gem)"},"fix":{"suggestedVersion":"2.9.0"}}],"artifact":{"id":"6e6d83a9e89cfebe","name":"addressable","version":"2.8.9","type":"gem","locations":[{"path":"/Gemfile.lock","accessPath":"/Gemfile.lock","annotations":{"evidence":"primary"}}],"language":"ruby","licenses":[],"cpes":["cpe:2.3:a:addressable:addressable:2.8.9:*:*:*:*:*:*:*","cpe:2.3:a:ruby-lang:addressable:2.8.9:*:*:*:*:*:*:*","cpe:2.3:a:ruby_lang:addressable:2.8.9:*:*:*:*:*:*:*","cpe:2.3:a:ruby:addressable:2.8.9:*:*:*:*:*:*:*"],"purl":"pkg:gem/addressable@2.8.9","upstreams":[]}},{"vulnerability":{"id":"GHSA-r6h4-mm7h-8pmq","dataSource":"https://github.com/advisories/GHSA-r6h4-mm7h-8pmq","namespace":"github:language:python","severity":"Low","urls":["https://github.com/facelessuser/pymdown-extensions/security/advisories/GHSA-r6h4-mm7h-8pmq","https://nvd.nist.gov/vuln/detail/CVE-2025-68142","https://github.com/facelessuser/pymdown-extensions/commit/b50d15a56850ed1408a284bba81cc019c6bd72e8","https://pypi.org/project/pymdown-extensions/10.16.1"],"description":"PyMdown Extensions has a ReDOS bug in its Figure Capture extension","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:N/VI:N/VA:L/SC:N/SI:N/SA:N/E:U","metrics":{"baseScore":2.7},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-68142","epss":0.00096,"percentile":0.26536,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-68142","cwe":"CWE-1333","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["10.16.1"],"state":"fixed","available":[{"version":"10.16.1","date":"2025-12-17","kind":"first-observed"}]},"advisories":[],"risk":0.027360000000000002},"relatedVulnerabilities":[{"id":"CVE-2025-68142","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-68142","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/facelessuser/pymdown-extensions/commit/b50d15a56850ed1408a284bba81cc019c6bd72e8","https://github.com/facelessuser/pymdown-extensions/security/advisories/GHSA-r6h4-mm7h-8pmq","https://pypi.org/project/pymdown-extensions/10.16.1"],"description":"PyMdown Extensions is a set of extensions for the `Python-Markdown` markdown project. Versions prior to 10.16.1 have a ReDOS bug found within the figure caption extension (`pymdownx.blocks.caption`). In systems that take unchecked user content, this could cause long hanges when processing the data if a malicious payload was crafted. This issue is patched in Release 10.16.1. As a workaround, those who process unknown user content without timeouts or other safeguards in place to prevent really large, malicious content being aimed at systems may avoid the use of `pymdownx.blocks.caption` until they're able to upgrade.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:N/VI:N/VA:L/SC:N/SI:N/SA:N/E:U/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":2.7},"vendorMetadata":{}}],"epss":[{"cve":"C