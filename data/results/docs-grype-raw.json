:N/SI:N/SA:N/E:P","metrics":{"baseScore":5.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-69534","epss":0.00368,"percentile":0.58786,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-69534","cwe":"CWE-400","source":"134c704f-9b21-4f2e-91b3-4a467353bcc0","type":"Secondary"}],"fix":{"versions":["3.8.1"],"state":"fixed","available":[{"version":"3.8.1","date":"2026-03-06","kind":"first-observed"}]},"advisories":[],"risk":0.21159999999999998},"relatedVulnerabilities":[{"id":"CVE-2025-69534","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-69534","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/Python-Markdown/markdown","https://github.com/Python-Markdown/markdown/actions/runs/15736122892","https://github.com/Python-Markdown/markdown/issues/1534","http://www.openwall.com/lists/oss-security/2026/03/06/4"],"description":"Python-Markdown version 3.8 contain a vulnerability where malformed HTML-like sequences can cause html.parser.HTMLParser to raise an unhandled AssertionError during Markdown parsing. Because Python-Markdown does not catch this exception, any application that processes attacker-controlled Markdown may crash. This enables remote, unauthenticated Denial of Service in web applications, documentation systems, CI/CD pipelines, and any service that renders untrusted Markdown. The issue was acknowledged by the vendor and fixed in version 3.8.1. This issue causes a remote Denial of Service in any application parsing untrusted Markdown, and can lead to Information Disclosure through uncaught exceptions.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"134c704f-9b21-4f2e-91b3-4a467353bcc0","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-69534","epss":0.00368,"percentile":0.58786,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-69534","cwe":"CWE-400","source":"134c704f-9b21-4f2e-91b3-4a467353bcc0","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"markdown","version":"3.6"}},"found":{"vulnerabilityID":"GHSA-5wmx-573v-2qwq","versionConstraint":"<3.8.1 (python)"},"fix":{"suggestedVersion":"3.8.1"}}],"artifact":{"id":"97d996c0ec4b20ee","name":"markdown","version":"3.6","type":"python","locations":[{"path":"/Pipfile.lock","accessPath":"/Pipfile.lock"}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-markdown:python-markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python-markdown:python_markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python_markdown:python-markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python_markdown:python_markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:markdown:python-markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:markdown:python_markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python-markdown:markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python_markdown:markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python:python-markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python:python_markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:markdown:markdown:3.6:*:*:*:*:*:*:*","cpe:2.3:a:python:markdown:3.6:*:*:*:*:*:*:*"],"purl":"pkg:pypi/markdown@3.6","upstreams":[]}},{"vulnerability":{"id":"GHSA-cpwx-vrp4-4pq7","dataSource":"https://github.com/advisories/GHSA-cpwx-vrp4-4pq7","namespace":"github:language:python","severity":"Medium","urls":["https://github.com/pallets/jinja/security/advisories/GHSA-cpwx-vrp4-4pq7","https://github.com/pallets/jinja/commit/90457bbf33b8662926ae65cdde4c4c32e756e403","https://nvd.nist.gov/vuln/detail/CVE-2025-27516","https://lists.debian.org/debian-lts-announce/2025/04/msg00045.html","https://lists.debian.org/debian-lts-announce/2025/04/msg00022.html"],"description":"Jinja2 vulnerable to sandbox breakout through attr filter selecting format method","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:L/AC:L/AT:P/PR:L/UI:P/VC:H/VI:H/VA:H/SC:N/SI:N/SA:N","metrics":{"baseScore":5.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-27516","epss":0.00119,"percentile":0.30762,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-27516","cwe":"CWE-1336","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["3.1.6"],"state":"fixed","available":[{"version":"3.1.6","date":"2025-03-06","kind":"first-observed"}]},"advisories":[],"risk":0.061880000000000004},"relatedVulnerabilities":[{"id":"CVE-2025-27516","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-27516","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/pallets/jinja/commit/90457bbf33b8662926ae65cdde4c4c32e756e403","https://github.com/pallets/jinja/security/advisories/GHSA-cpwx-vrp4-4pq7","https://lists.debian.org/debian-lts-announce/2025/04/msg00022.html","https://lists.debian.org/debian-lts-announce/2025/04/msg00045.html"],"description":"Jinja is an extensible templating engine. Prior to 3.1.6, an oversight in how the Jinja sandboxed environment interacts with the |attr filter allows an attacker that controls the content of a template to execute arbitrary Python code. To exploit the vulnerability, an attacker needs to control the content of a template. Whether that is the case depends on the type of application using Jinja. This vulnerability impacts users of applications which execute untrusted templates. Jinja's sandbox does catch calls to str.format and ensures they don't escape the sandbox. However, it's possible to use the |attr filter to get a reference to a string's plain format method, bypassing the sandbox. After the fix, the |attr filter no longer bypasses the environment's attribute lookup. This vulnerability is fixed in 3.1.6.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:L/AC:L/PR:L/UI:N/S:C/C